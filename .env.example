# Supabase project settings → API
# https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# The absolute origin this deployment is served at (e.g. https://app.example.com).
# Used to build Supabase Auth redirect URLs (e.g. signup confirmation emails)
# so they point back at this deployment instead of Supabase's default Site URL.
# Must also be added to the Supabase project's Auth > URL Configuration >
# Redirect URLs allow list. Leave unset locally to fall back to localhost.
NEXT_PUBLIC_SITE_URL=

# QA Playwright test account — must already exist in Supabase with a confirmed email
QA_TEST_EMAIL=
QA_TEST_PASSWORD=


